STRATEGYLAB_ENV=development
STRATEGYLAB_LOG_LEVEL=INFO
STRATEGYLAB_STORAGE_ROOT=./storage
STRATEGYLAB_ARTIFACT_ROOT=./artifacts
STRATEGYLAB_DATABASE_URL=postgresql+psycopg://strategylab:strategylab@localhost:5432/strategylab
STRATEGYLAB_REDIS_URL=redis://localhost:6379/0
STRATEGYLAB_MLFLOW_TRACKING_URI=file:./.mlruns
STRATEGYLAB_DEFAULT_MONTE_CARLO_RUNS=500
STRATEGYLAB_RANDOM_SEED=44

